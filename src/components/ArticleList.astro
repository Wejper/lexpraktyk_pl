---
import { getCoverImage } from '../utils/cover';
import type { CollectionEntry } from 'astro:content';

interface Props {
  articles: CollectionEntry<'articles'>[];
}

const { articles } = Astro.props;

const covers = await Promise.all(
  articles.map((a) => getCoverImage(a.data.cover, a.data.tags, a.data.coverQuery, a.id))
);
---

{articles.length === 0 && (
  <p class="t-mono" style="color:var(--ink-faint);">Brak artykułów.</p>
)}

<div style="display:flex; flex-direction:column; gap:0;">
  {articles.map((article, i) => (
    <article
      class="card card-article"
      style="display:grid; grid-template-columns:180px 1fr; overflow:hidden; margin-bottom:16px; position:relative;"
    >
      <img
        src={covers[i]}
        alt={article.data.title}
        style="width:100%; height:140px; object-fit:cover; display:block;"
        loading="lazy"
      />
      <div style="padding:14px 18px; display:flex; flex-direction:column; gap:6px;">
        {article.data.tags && (
          <div style="display:flex; gap:6px; flex-wrap:wrap; position:relative; z-index:2;">
            {article.data.tags.slice(0,3).map(tag => (
              <a href={`/tag/${encodeURIComponent(tag)}`} class="tag warm">#{tag}</a>
            ))}
          </div>
        )}
        <h3 class="h-title" style="font-size:20px; margin:2px 0;">
          <a href={`/artykuly/${article.id}`} class="stretched-link">{article.data.title}</a>
        </h3>
        <p class="t-body" style="color:var(--ink-soft); margin:0; font-size:14px;">{article.data.description}</p>
        <div class="t-mono" style="margin-top:auto;">
          {article.data.author && <span>{article.data.author} · </span>}
          {article.data.publishDate.toLocaleDateString('pl-PL')}
        </div>
      </div>
    </article>
  ))}
</div>
