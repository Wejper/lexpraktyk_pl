---
import { SEO } from 'astro-seo';
import '../styles/global.css';
import { CATEGORIES } from '../utils/categories';

interface Props {
  title: string;
  description: string;
  image?: string;
}

const { title, description, image } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const year = new Date().getFullYear();
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Analytics placeholder -->
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.bunny.net">
    <link href="https://fonts.bunny.net/css?family=geist:400,500,600|geist-mono:400,500" rel="stylesheet">
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL.toString()}
      openGraph={{
        basic: {
          title,
          type: 'website',
          image: image ?? '/og-default.jpg',
          url: canonicalURL.toString(),
        },
        optional: {
          description,
          siteName: 'lexpraktyk.pl — praktyczny portal prawny',
          locale: 'pl_PL',
        },
      }}
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <div class="row">
          <a class="brand" href="/"><span class="dot"></span>lexpraktyk.pl</a>
          <button class="menu-btn" id="menu-btn" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
          </button>
          <nav class="nav" id="main-nav">
            {Object.entries(CATEGORIES).map(([slug, { label }]) => (
              <a
                href={`/${slug}`}
                class={Astro.url.pathname.startsWith(`/${slug}`) ? 'active' : ''}
              >
                {label}
              </a>
            ))}
          </nav>
          <div class="flex-1"></div>
        </div>
      </div>
    </header>

    <main class="container" style="padding-top: 24px; min-height: 60vh;">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="cols">
          <!-- Col 1: Brand + tagline -->
          <div>
            <a class="brand" href="/" style="margin-bottom: 10px; display: inline-flex;"><span class="dot"></span>lexpraktyk.pl</a>
            <p class="t-body" style="margin: 10px 0 0; font-size: 13px; color: var(--ink-soft);">
              Praktyczny przewodnik prawny dla zwykłych ludzi.
            </p>
          </div>
          <!-- Col 2: Kategorie -->
          <div>
            <h4>Kategorie</h4>
            <ul>
              {Object.entries(CATEGORIES).map(([slug, { label }]) => (
                <li><a href={`/${slug}`}>{label}</a></li>
              ))}
            </ul>
          </div>
          <!-- Col 3: Redakcja -->
          <div>
            <h4>Redakcja</h4>
            <ul>
              <li><a href="#">O nas</a></li>
              <li><a href="#">Zasady recenzji</a></li>
              <li><a href="#">Ujawnienia partnerskie</a></li>
              <li><a href="#">Kontakt</a></li>
            </ul>
          </div>
          <!-- Col 4: Newsletter -->
          <div>
            <h4>Newsletter</h4>
            <p class="t-small" style="margin: 0 0 10px;">Raz w tygodniu — nowe poradniki, wzory pism, jedna konkretna porada prawna.</p>
            <div style="display: flex; gap: 6px;">
              <input
                type="email"
                placeholder="twój@email.pl"
                style="flex: 1; padding: 7px 10px; border: 1px solid var(--rule-strong); border-radius: var(--r-sm); font-family: var(--sans); font-size: 13px; background: var(--paper); color: var(--ink); outline: none;"
              />
              <button class="btn btn-warm btn-sm">Zapisz</button>
            </div>
          </div>
        </div>
        <div class="bottom">
          <span>© {year} lexpraktyk.pl · wszystkie prawa zastrzeżone</span>
          <span>polityka prywatności · regulamin · RSS</span>
        </div>
      </div>
    </footer>
  </body>
  <script>
    const btn = document.getElementById('menu-btn');
    const nav = document.getElementById('main-nav');
    btn?.addEventListener('click', () => {
      const open = nav?.classList.toggle('nav-open');
      btn.setAttribute('aria-expanded', String(open));
    });
  </script>
</html>
