---
import { SEO } from 'astro-seo';
import '../styles/global.css';
import { CATEGORIES } from '../utils/categories';

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
}

const { title, description, image, noindex } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const year = new Date().getFullYear();
---

<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=IBM+Plex+Sans:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
    <SEO
      title={title}
      description={description}
      canonical={canonicalURL.toString()}
      noindex={noindex}
      openGraph={{
        basic: {
          title,
          type: 'website',
          image: image ?? '/og-default.jpg',
          url: canonicalURL.toString(),
        },
        optional: {
          description,
          siteName: 'lexpraktyk.pl — praktyczny portal prawny',
          locale: 'pl_PL',
        },
      }}
    />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <div class="row">
          <a class="brand" href="/" aria-label="lexpraktyk.pl">
            <span class="mark-col" aria-hidden="true">
              <span class="l">l</span>
              <span class="pillar"></span>
              <span class="pillar"></span>
            </span>
            <span>lexpraktyk</span>
            <span class="tld">.pl</span>
          </a>
          <button class="menu-btn" id="menu-btn" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
          </button>
          <nav class="nav" id="main-nav">
            {Object.entries(CATEGORIES).map(([slug, { label }]) => (
              <a href={`/${slug}`} class={Astro.url.pathname.startsWith(`/${slug}`) ? 'active' : ''}>
                {label}
              </a>
            ))}
            <a href="/wzory" class={Astro.url.pathname.startsWith('/wzory') ? 'active' : ''}>Wzory pism</a>
            <a href="/kancelarie" class={Astro.url.pathname.startsWith('/kancelarie') ? 'active' : ''}>Kancelarie</a>
          </nav>
          <div class="flex-1"></div>
          <a class="cta-pill" href="/reputacja">Zgłoś sprawę →</a>
        </div>
      </div>
    </header>

    <main class="container" style="padding-top: 28px; min-height: 60vh;">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div class="cols">
          <!-- Col 1: Brand + blurb -->
          <div>
            <a class="brand" href="/" style="margin-bottom: 12px; display: inline-flex;">
              <span class="mark-col" aria-hidden="true">
                <span class="l">l</span>
                <span class="pillar"></span>
                <span class="pillar"></span>
              </span>
              <span>lexpraktyk</span>
              <span class="tld">.pl</span>
            </a>
            <p class="t-small" style="max-width: 340px; margin: 0;">
              Treści mają charakter informacyjny i nie stanowią porady prawnej.
              W indywidualnej sprawie skonsultuj się z adwokatem lub radcą prawnym.
            </p>
          </div>
          <!-- Col 3: Kategorie -->
          <div>
            <h4>Kategorie</h4>
            <ul>
              {Object.entries(CATEGORIES).map(([slug, { label }]) => (
                <li><a href={`/${slug}`}>{label}</a></li>
              ))}
              <li><a href="/wzory">Wzory pism</a></li>
              <li><a href="/kancelarie">Kancelarie</a></li>
            </ul>
          </div>
          <!-- Col 4: Newsletter -->
          <div>
            <h4>Newsletter</h4>
            <p class="t-small" style="margin: 0 0 10px;">
              Jeden mail w tygodniu — nowe orzecznictwo, jedna sprawa z praktyki, jedno użyteczne pismo.
            </p>
            <div style="display: flex; gap: 6px;">
              <input
                type="email"
                placeholder="twój@email.pl"
                style="flex: 1; padding: 9px 12px; border: 1px solid var(--rule-strong); border-radius: var(--r-sm); font-family: var(--sans); font-size: 14px; background: var(--paper-pure); color: var(--ink); outline: none;"
              />
              <button class="btn btn-accent btn-sm">Zapisz</button>
            </div>
          </div>
        </div>
        <div class="bottom">
          <span>© {year} lexpraktyk.pl · wszystkie prawa zastrzeżone</span>
          <span>regulamin · polityka prywatności · cookies · RSS</span>
        </div>
      </div>
    </footer>
  </body>
  <script>
    const btn = document.getElementById('menu-btn');
    const nav = document.getElementById('main-nav');
    btn?.addEventListener('click', () => {
      const open = nav?.classList.toggle('nav-open');
      btn.setAttribute('aria-expanded', String(open));
    });
  </script>
</html>
