---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleList from '../components/ArticleList.astro';
import { getCoverImage } from '../utils/cover';
import { CATEGORIES } from '../utils/categories';

const now = new Date();
const allArticles = (await getCollection('articles', ({ data }) => data.published && new Date(data.publishDate) <= now))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featured = allArticles[0];
const latest = allArticles.slice(1);

const featuredCover = featured ? await getCoverImage(featured.data.cover, featured.data.tags, featured.data.coverQuery, featured.id) : '';

const articleCount = allArticles.length;

// Category counts
const categoryCounts: Record<string, number> = {};
for (const [slug, { tags: catTags }] of Object.entries(CATEGORIES)) {
  categoryCounts[slug] = allArticles.filter(a => a.data.tags?.some(t => (catTags as readonly string[]).includes(t))).length;
}

// "Co czytają" trio — one unique article per first 3 categories
const trioCats = ['nieruchomosci', 'biznes', 'reputacja'] as const;
const usedIds = new Set<string>();
const trioArticles = await Promise.all(
  trioCats.map(async (cat) => {
    const catTags = CATEGORIES[cat].tags as readonly string[];
    const article = allArticles.find(a => !usedIds.has(a.id) && a.data.tags?.some(t => catTags.includes(t)));
    if (article) usedIds.add(article.id);
    const cover = article ? await getCoverImage(article.data.cover, article.data.tags, article.data.coverQuery, article.id) : '';
    return { cat, article, cover, label: CATEGORIES[cat].label };
  })
);

const popularTags = ['zachowek','testament','notariusz','księga wieczysta','wypowiedzenie','zakaz konkurencji','windykacja','pomówienie','RODO','deweloper'];
---

<BaseLayout
  title="lexpraktyk.pl – praktyczny portal prawny"
  description="Dziedziczenie, nieruchomości, ochrona dobrego imienia — praktyczne poradniki prawne krok po kroku, bez żargonu."
>
  <!-- Masthead bar -->
  <div style="display:flex; align-items:baseline; justify-content:space-between; padding: 8px 0 24px; border-bottom: 1px solid var(--rule);">
    <div>
      <div class="h-eyebrow">{now.toLocaleDateString('pl-PL', { month: 'long', year: 'numeric' })}</div>
      <div class="t-script" style="font-size:13.5px; margin-top:4px;">
        Praktyczny przewodnik prawny dla zwykłych ludzi — bez żargonu, krok po kroku.
      </div>
    </div>
    <div class="t-mono" style="text-align:right;">
      <div>{articleCount} artykułów</div>
      <div style="margin-top:2px;">ostatnia aktualizacja: dziś</div>
    </div>
  </div>

  <!-- Hero featured article -->
  {featured && (
    <section style="margin: 32px 0;">
      <article class="card hero-card" style="display:grid; grid-template-columns: 1.2fr 1fr; overflow:hidden;">
        <img
          src={featuredCover}
          alt={featured.data.title}
          style="width:100%; height:360px; object-fit:cover; display:block;"
        />
        <div style="padding: 32px; display:flex; flex-direction:column; gap:12px; justify-content:center;">
          {featured.data.tags && (
            <div style="display:flex; gap:6px; flex-wrap:wrap; position:relative; z-index:2;">
              {featured.data.tags.slice(0,3).map(tag => (
                <a href={`/tag/${encodeURIComponent(tag)}`} class="tag warm">#{tag}</a>
              ))}
            </div>
          )}
          <h2 class="h-display" style="font-size:38px; font-weight:600; letter-spacing:-0.035em; margin:0;">
            <a href={`/artykuly/${featured.id}`} class="stretched-link">{featured.data.title}</a>
          </h2>
          <p class="t-body" style="color:var(--ink-soft); margin:0;">{featured.data.description}</p>
          <div class="t-mono" style="margin-top:4px;">
            {featured.data.publishDate.toLocaleDateString('pl-PL')}
          </div>
          <div style="margin-top:8px; position:relative; z-index:2;">
            <a href={`/artykuly/${featured.id}`} class="btn btn-primary">Czytaj artykuł →</a>
          </div>
        </div>
      </article>
    </section>
  )}

  <!-- Latest + Sidebar -->
  <div class="home-grid" style="display:grid; grid-template-columns: 1fr 320px; gap: 48px; margin-bottom: 48px;">
    <section>
      <div style="display:flex; align-items:baseline; justify-content:space-between; margin-bottom:16px;">
        <h2 class="h-headline" style="font-size:18px; margin:0;">Najnowsze</h2>
        <a href="#" class="t-mono" style="color:var(--warm-deep);">wszystkie artykuły →</a>
      </div>
      <ArticleList articles={latest.slice(0,8)} />
      {latest.length > 8 && (
        <>
          <div id="more-articles" style="display:none;">
            <ArticleList articles={latest.slice(8)} />
          </div>
          <div style="display:flex; justify-content:center; margin-top:28px;" id="load-more-wrap">
            <button class="btn" id="load-more-btn">Załaduj więcej</button>
          </div>
        </>
      )}
    </section>

    <aside style="display:flex; flex-direction:column; gap:24px;">
      <!-- Categories card -->
      <div class="card" style="padding:20px; overflow:visible;">
        <h3 class="h-eyebrow" style="margin:0 0 12px;">Kategorie</h3>
        {Object.entries(CATEGORIES).map(([slug, { label }]) => (
          <a
            href={`/${slug}`}
            style="display:flex; justify-content:space-between; align-items:baseline; padding:8px 0; border-bottom:1px solid var(--rule);"
          >
            <span class="h-title" style="font-size:13px;">{label}</span>
            <span class="t-mono">{categoryCounts[slug] ?? 0}</span>
          </a>
        ))}
      </div>

      <!-- Newsletter card -->
      <div class="card card-warm" style="padding:20px; overflow:visible;">
        <h3 class="h-headline" style="font-size:16px; margin:0 0 6px; color:var(--warm-deep);">Newsletter</h3>
        <p class="t-small" style="color:var(--warm-deep); margin-top:0; margin-bottom:12px;">
          Raz w tygodniu — ceny paliw, nowe poradniki, jedna konkretna porada.
        </p>
        <div style="display:flex; gap:6px;">
          <input
            type="email"
            placeholder="twój@email.pl"
            style="flex:1; padding:8px 10px; border:1px solid var(--warm); border-radius:6px; background:#fff; font-family:var(--sans); font-size:14px;"
          />
          <button class="btn btn-warm btn-sm">Zapisz</button>
        </div>
        <div class="t-mono" style="color:var(--warm-deep); margin-top:8px; font-size:11px;">bez spamu</div>
      </div>

      <!-- Popular tags -->
      <div class="card" style="padding:20px; overflow:visible;">
        <h3 class="h-eyebrow" style="margin:0 0 12px;">Popularne tagi</h3>
        <div style="display:flex; flex-wrap:wrap; gap:6px;">
          {popularTags.map(t => (
            <a href={`/tag/${encodeURIComponent(t)}`} class="tag warm">#{t}</a>
          ))}
        </div>
      </div>

      <!-- Archive mini-list -->
      <div style="padding:20px 0; border-top:1px solid var(--rule);">
        <h3 class="h-eyebrow" style="margin:0 0 12px;">Z archiwum</h3>
        <div style="display:flex; flex-direction:column; gap:10px;">
          {latest.slice(8, 12).map(a => (
            <a href={`/artykuly/${a.id}`} style="display:block;">
              <div class="h-title" style="font-size:13px; margin-bottom:2px;">{a.data.title}</div>
              <div class="t-mono">{a.data.publishDate.toLocaleDateString('pl-PL')}</div>
            </a>
          ))}
        </div>
      </div>
    </aside>
  </div>

  <!-- "Co czytają w tym tygodniu" trio -->
  <div class="section-head" style="margin-top:64px;">
    <div>
      <div class="h-eyebrow">Przekrój</div>
      <h2 class="h-headline">Co czytają w tym tygodniu</h2>
    </div>
    <a href="#" class="t-mono" style="color:var(--warm-deep);">archiwum →</a>
  </div>
  <div class="trio-grid" style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:20px; margin-bottom:64px;">
    {trioArticles.map(({ cat, article, cover, label }) => article && (
      <div class="card" style="overflow:hidden;">
        <img src={cover} alt={label} style="width:100%; height:180px; object-fit:cover; display:block;" />
        <div style="padding:18px;">
          <a href={`/${cat}`} class="h-eyebrow" style="color:var(--warm-deep); display:block; margin-bottom:6px;">{label} →</a>
          <h3 class="h-title" style="font-size:15px; margin:0 0 8px;">
            <a href={`/artykuly/${article.id}`}>{article.data.title}</a>
          </h3>
          <p class="t-body" style="font-size:14px; color:var(--ink-soft); margin:0;">{article.data.description}</p>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<script>
  const btn = document.getElementById('load-more-btn');
  const more = document.getElementById('more-articles');
  const wrap = document.getElementById('load-more-wrap');
  btn?.addEventListener('click', () => {
    if (more) more.style.display = 'block';
    if (wrap) wrap.style.display = 'none';
  });
</script>
