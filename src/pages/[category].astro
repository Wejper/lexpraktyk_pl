---
export const prerender = false;

import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleList from '../components/ArticleList.astro';
import NotFound from '../components/NotFound.astro';
import { CATEGORIES, type CategorySlug } from '../utils/categories';

const { category } = Astro.params as { category: CategorySlug };
const isValid = category && category in CATEGORIES;

if (!isValid) Astro.response.status = 404;

const { label, description, num, tagline, tags: categoryTags } = isValid
  ? CATEGORIES[category]
  : { label: '', description: '', num: '', tagline: '', tags: [] };

const now = new Date();
const articles = isValid
  ? (await getCollection('articles', ({ data }) => data.published && new Date(data.publishDate) <= now))
      .filter((a) => a.data.tags?.some((t) => (categoryTags as readonly string[]).includes(t)))
      .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  : [];
---

{isValid ? (
  <BaseLayout title={`${label} – lexpraktyk.pl`} description={description}>
    <div style="padding: 10px 0 32px; border-bottom: 1px solid var(--ink);">
      <div class="t-mono">
        <a href="/" style="color: var(--ink-soft);">lexpraktyk.pl</a>
        <span style="margin: 0 6px; color: var(--ink-faint);">·</span>
        <span>{category}</span>
      </div>
      <div style="display: flex; align-items: baseline; gap: 14px; margin-top: 18px;">
        {num && <span style="font-family: var(--serif); font-style: italic; font-size: 72px; color: var(--accent); line-height: 0.9;">{num}</span>}
        <h1 class="h-display" style="font-size: 64px; margin: 0;">{label}</h1>
      </div>
      <p class="t-script" style="font-size: 22px; margin-top: 14px; margin-bottom: 0; max-width: 760px;">{tagline}</p>
    </div>
    <div style="margin-top: 32px;">
      <ArticleList articles={articles} />
    </div>
  </BaseLayout>
) : (
  <NotFound />
)}
